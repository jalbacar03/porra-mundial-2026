{
  "crons": [
    {
      "path": "/api/sync-results",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/send-daily-digest",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/generate-insight",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/notify",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/notify-round-open",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/notify-knockout-open",
      "schedule": "30 5 28 6 *"
    },
    {
      "path": "/api/snapshot-group-stage",
      "schedule": "0 13 28 6 *"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|assets/|.*\\..*).*)",
      "destination": "/index.html"
    },
    {
      "source": "/assets/(.*\\.js)",
      "destination": "/chunk-recover.js"
    }
  ]
}
